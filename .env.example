# Required: Supabase authentication and data access
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: canonical production origin for authentication and team invitation links
# Example: https://jamals-finance-sable.vercel.app
NEXT_PUBLIC_APP_URL=

# Required before public commercial launch: dedicated user/privacy support inbox
# Example: support@your-domain.com
NEXT_PUBLIC_SUPPORT_EMAIL=

# Optional: enable only after configuring the Supabase Google provider
NEXT_PUBLIC_ENABLE_GOOGLE_AUTH=false

# Optional: privacy-minimised product and performance telemetry.
# Keep false until the matching Supabase migration is applied and verified.
NEXT_PUBLIC_TELEMETRY_ENABLED=false

# Optional: production monitoring and source-map upload
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# Optional: AI insights for Personal Finance only.
# Business, POS, dealership, restaurant, company, and enterprise data must never
# be sent to an AI provider through this billing node.
GEMINI_API_KEY=
GEMINI_MODEL=

# Optional: market and exchange-rate providers
# Keep provider keys server-side. Twelve Data is the preferred global quote
# provider; Finnhub is an optional stock-search/quote fallback.
TWELVE_DATA_API_KEY=
FINNHUB_API_KEY=
COINGECKO_DEMO_API_KEY=
COINGECKO_PRO_API_KEY=
ALPHA_VANTAGE_API_KEY=
EXCHANGE_RATE_API_KEY=

# Paddle Billing (sandbox until commercial launch approval is complete)
# Keep false until products, regional overrides, migrations, Edge Function
# webhook verification, and full sandbox lifecycle tests are complete.
BILLING_CHECKOUT_ENABLED=false
NEXT_PUBLIC_PADDLE_ENV=sandbox
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
PADDLE_API_KEY=

# Set these as Supabase Edge Function secrets for paddle-webhook.
# Never prefix either value with NEXT_PUBLIC_.
PADDLE_WEBHOOK_SECRET=
PADDLE_WEBHOOK_TOLERANCE_SECONDS=300

# Personal Finance Paddle price IDs
PADDLE_PRICE_GO_MONTHLY=
PADDLE_PRICE_GO_ANNUAL=
PADDLE_PRICE_STUDENT_MONTHLY=
PADDLE_PRICE_STUDENT_ANNUAL=
PADDLE_PRICE_PLUS_MONTHLY=
PADDLE_PRICE_PLUS_ANNUAL=
PADDLE_PRICE_PRO_MONTHLY=
PADDLE_PRICE_PRO_ANNUAL=

# Business workspace Paddle price IDs
PADDLE_PRICE_SOLO_MONTHLY=
PADDLE_PRICE_SOLO_ANNUAL=
PADDLE_PRICE_STARTER_MONTHLY=
PADDLE_PRICE_STARTER_ANNUAL=
PADDLE_PRICE_GROWTH_MONTHLY=
PADDLE_PRICE_GROWTH_ANNUAL=
PADDLE_PRICE_SCALE_MONTHLY=
PADDLE_PRICE_SCALE_ANNUAL=

# Enterprise uses a reviewed contract/invoice flow, not self-service checkout.

# Optional: Stripe integration for a future provider migration
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
