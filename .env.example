# Required: Supabase authentication and data access
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: canonical production origin for authentication and team invitation links
# Example: https://app.your-domain.com
NEXT_PUBLIC_APP_URL=

# Required before public commercial launch: dedicated user/privacy support inbox
# Example: support@your-domain.com
NEXT_PUBLIC_SUPPORT_EMAIL=

# Optional: enable only after configuring the Supabase Google provider
NEXT_PUBLIC_ENABLE_GOOGLE_AUTH=false

# Optional: production monitoring and source-map upload
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# Optional: AI insights
GEMINI_API_KEY=
GEMINI_MODEL=

# Optional: market and exchange-rate providers
# Keep provider keys server-side. Twelve Data is the preferred global quote
# provider; Finnhub is an optional stock-search/quote fallback.
TWELVE_DATA_API_KEY=
FINNHUB_API_KEY=
COINGECKO_DEMO_API_KEY=
COINGECKO_PRO_API_KEY=
ALPHA_VANTAGE_API_KEY=
EXCHANGE_RATE_API_KEY=

# Optional: Stripe integration
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
